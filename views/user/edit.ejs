<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Hopefield Homecare</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    <div class="grid">  
        <div class="content_section">
            <div class="profile-card">
                <form action="/user/profile/edit" method="POST" id="editProfileForm">
                    <h3>Personal Details</h3>

                    <label>Username:</label>
                    <input type="text" name="username" value="<%= user.username %>" required>

                    <label>Forename:</label>
                    <input type="text" name="userForename" value="<%= user.userForename %>" required>

                    <label>Surname:</label>
                    <input type="text" name="userSurname" value="<%= user.userSurname %>" required>

                    <label>Phone Number:</label>
                    <input type="text" name="phoneNumber" value="<%= user.phoneNumber || '' %>">

                    <label>Birthday:</label>
                    <input type="date" name="userDOB" value="<%= dob %>">

                    <hr>

                    <h3>Change Password</h3>
                    
                    <div class="form-group">
                        <label for="oldPassword">Current Password:</label>
                        <input type="password" name="oldPassword" id="oldPassword" placeholder="Enter current password">
                    </div>

                    <div class="form-group">
                        <label for="newPassword">New Password:</label>
                        <div class="password-container">
                            <input type="password" name="newPassword" id="password" placeholder="Enter new password">
                            <button type="button" id="togglePass" class="toggle-password">Show</button>
                        </div>
                        <div class="meter-container">
                            <div id="power-point"></div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="save-btn">Save Changes</button>
                        <a href="/user/profile" class="cancel-btn">Cancel</a>
                    </div>

                    <script>
                        const passwordInput = document.getElementById("password");
                        const oldPasswordInput = document.getElementById("oldPassword");
                        const power = document.getElementById("power-point");
                        const editForm = document.getElementById("editProfileForm");
                        const togglePassBtn = document.getElementById("togglePass");
                        let currentPoints = 0;

                        togglePassBtn.addEventListener('click', function() {
                            const isPassword = passwordInput.getAttribute('type') === 'password';
                            passwordInput.setAttribute('type', isPassword ? 'text' : 'password');
                            this.textContent = isPassword ? 'Hide' : 'Show';
                        });

                        // GeeksforGeeks (2023) Create a Password Strength Checker using HTML CSS and JavaScript, GeeksforGeeks. Available at: https://www.geeksforgeeks.org/javascript/create-a-password-strength-checker-using-html-css-and-javascript/.
                        passwordInput.oninput = function () {
                            let point = 0;
                            let value = passwordInput.value;
                            let widthPower = ["1%", "25%", "50%", "75%", "100%"];
                            let colorPower = ["#D73F40", "#DC6551", "#F2B84F", "#BDE952", "#3ba62f"];

                            if (value.length > 0 && value.length < 6) {
                                point = 0; 
                            } else if (value.length >= 6) {
                                let arrayTest = [/[0-9]/, /[a-z]/, /[A-Z]/, /[^0-9a-zA-Z]/];
                                arrayTest.forEach((item) => {
                                    if (item.test(value)) point += 1;
                                });
                            }
                            
                            currentPoints = point;
                            power.style.width = widthPower[point];
                            power.style.backgroundColor = colorPower[point];
                        };

                        editForm.onsubmit = function(e) {
                            const newPassValue = passwordInput.value;
                            const oldPassValue = oldPasswordInput.value;

                            if (newPassValue.length > 0) {
                                if (oldPassValue === "") {
                                    e.preventDefault();
                                    alert("You must enter your current password to set a new one.");
                                    return false;
                                }
                                if (currentPoints < 3) {
                                    e.preventDefault();
                                    alert("New password is too weak. Please include a mix of uppercase, lowercase, numbers, and symbols.");
                                    return false;
                                }
                            }
                        };
                    </script>
                </form>
            </div>
        </div>
    </div>
    <%- include('partials/footer')%>
</body>
</html>