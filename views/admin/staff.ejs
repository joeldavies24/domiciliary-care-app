<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hopefield Homecare</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    <div class="grid">
        <div class="content_section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>Staff List</h2>
                <a href="/admin/create/user" class="button-link">Register New Staff</a>
            </div>

            <input type="text" id="staffSearch" class="search-input" placeholder="Search by name, username, or role...">

            <div class="table-scroll">
                <table class="timetable">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Name</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="staffTableBody">
                        <% users.filter(u => u.userType === 'carer' || u.userType === 'admin').forEach(function(obj){ %>
                            <tr data-search="<%= `${obj.username} ${obj.userForename} ${obj.userSurname} ${obj.userType}`.toLowerCase() %>">
                                <td><strong><%= obj.username %></strong></td>
                                <td><%= obj.userForename %> <%= obj.userSurname %></td>
                                <td>
                                    <span class="badge" style="text-transform: capitalize;">
                                        <%= obj.userType %>
                                    </span>
                                </td>
                                <td>
                                    <span class="status-badge <%= obj.userStatus ? 'status-resolved' : 'status-rejected' %>">
                                        <%= obj.userStatus ? "Active" : "Inactive" %>
                                    </span>
                                </td>
                                <td>

                                    <div style="display:flex; gap:15px; align-items:center;">
                                        <a href="/user/details/<%= obj._id %>" class="text-link btn-view">
                                            View
                                        </a>
                                        <a href="/admin/edit_user/<%= obj._id %>" class="text-link btn-edit">
                                            Edit
                                        </a>

                                        <% if(user._id.toString() !== obj._id.toString()) { %>
                                            <form action="/admin/delete_user/<%= obj._id %>" method="POST" onsubmit="return confirmDelete(this, '<%= obj.userType %>');">
                                                <input type="hidden" name="adminCode" class="adminCodeInput">
                                                <button type="submit" class="text-link btn-delete">
                                                    Delete
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <div>
            <a class="nav-btn" href="/admin/index">Back to Admin Dashboard</a>
        </div>
    </div>

    <script>
        document.getElementById('staffSearch').addEventListener('input', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#staffTableBody tr').forEach(row => {
                row.style.display = row.dataset.search.includes(filter) ? '' : 'none';
            });
        });

        function confirmDelete(form, userType) {
            if (userType === 'admin') {
                const code = prompt("Enter admin code to delete this admin account:");
                if (!code) return false;
                form.querySelector('.adminCodeInput').value = code;
            }
            return confirm('Delete this account?');
        }
    </script>
    <%- include('partials/footer')%>
</body>
</html>
