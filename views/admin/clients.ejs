<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hopefield Homecare</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    <div class="grid">
        <div class="content_section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>Client List</h2>
                <a href="/admin/create/user" class="button-link">Register New Client</a>
            </div>

            <input type="text" id="clientSearch" class="search-input" placeholder="Search by name, username, or NHS number...">

            <div class="table-scroll">
                <table class="timetable">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>NHS Number</th>
                            <th>DOB</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="clientTableBody">
                        <% users.filter(u => u.userType === 'client').forEach(function(obj){ %>
                            <tr data-search="<%= `${obj.userForename} ${obj.userSurname} ${obj.username} ${obj.nhsNumber || ''}`.toLowerCase() %>">
                                <td>
                                    <a href="/user/details/<%= obj._id %>" class="view-link" style="font-weight: bold;">
                                        <%= obj.userForename %> <%= obj.userSurname %>
                                    </a>
                                    <br><small class="text-muted">@<%= obj.username %></small>
                                </td>
                                <td><%= obj.nhsNumber || "N/A" %></td>
                                <td><%= obj.userDOB ? new Date(obj.userDOB).toLocaleDateString('en-GB') : "N/A" %></td>
                                <td>
                                    <span class="status-badge <%= obj.userStatus ? 'status-resolved' : 'status-rejected' %>">
                                        <%= obj.userStatus ? "Active" : "Inactive" %>
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex;gap:10px;align-items:center;">
                                        <a href="/user/details/<%= obj._id %>" class="text-link">
                                            View
                                        </a>

                                        <a href="/admin/edit_user/<%= obj._id %>" class="text-link" style="color:#3498db;">
                                            Edit
                                        </a>

                                        <form action="/admin/delete_user/<%= obj._id %>" method="POST" onsubmit="return confirm('Delete this client?');" style="display:contents;">
                                            <button type="submit" class="text-link" style="border:none;background:none;color:#dc3545;cursor:pointer;padding:0;">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <div>
            <a class="nav-btn" href="/admin/index">Back to Admin Dashboard</a>
        </div>
    </div>

    <script>
        document.getElementById('clientSearch').addEventListener('input', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#clientTableBody tr').forEach(row => {
                row.style.display = row.dataset.search.includes(filter) ? '' : 'none';
            });
        });
    </script>
    <%- include('partials/footer')%>
</body>
</html>
