<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hopefield Homecare</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('../partials/navbar', { user: user }) %>

    <div class="grid">
        <div class="content_section">
            <div class="profile-card">
                <h2>Edit Care Task</h2>
                <hr>

                <form action="/admin/edit_task/<%= task._id %>" method="POST">

                    <div class="form-group">
                        <label for="taskName">Task Name</label>
                        <input type="text" id="taskName" name="taskName" value="<%= task.taskName %>" required>
                    </div>

                    <div class="form-group">
                        <label for="category">Category</label>
                        <select id="category" name="category" required>
                            <option value="Medication" <%= task.category === 'Medication' ? 'selected' : '' %>>
                                Medication
                            </option>
                            <option value="Personal Care" <%= task.category === 'Personal Care' ? 'selected' : '' %>>
                                Personal Care
                            </option>
                            <option value="Mobility" <%= task.category === 'Mobility' ? 'selected' : '' %>>
                                Mobility
                            </option>
                            <option value="Nutrition" <%= task.category === 'Nutrition' ? 'selected' : '' %>>
                                Nutrition
                            </option>
                            <option value="Monitoring" <%= task.category === 'Monitoring' ? 'selected' : '' %>>
                                Monitoring
                            </option>
                            <option value="Other" <%= task.category === 'Other' ? 'selected' : '' %>>
                                Other
                            </option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="dosage">Dosage</label>
                        <input type="text" id="dosage" name="dosage" value="<%= task.dosage %>">
                    </div>

                    <div class="form-group">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" rows="5" required><%= task.description %></textarea>
                    </div>

                    <div style="display: flex; gap: 15px; margin-top: 20px;">
                        <button type="submit" class="button-link">
                            Save Changes
                        </button>

                        <a href="/admin/tasks" class="cancel-link">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>