<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hopefield Homecare</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    <div class="grid">
        <div class="nav-container">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>Request List</h2>
            </div>
            <div class="filter-group">
                <a href="/admin/requests" class="nav-btn <%= currentFilter === 'Pending' ? 'active-filter' : '' %>">Pending</a>
                <a href="/admin/requests?show=resolved" class="nav-btn <%= currentFilter === 'Resolved' ? 'active-filter' : '' %>">Resolved</a>
            </div>
        </div>

        <div class="table-scroll">
            <table class="timetable"> <thead>
                    <tr>
                        <th>User</th>
                        <th>Request Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (requests.length > 0) { %>
                        <% requests.forEach(req => { %>
                            <tr>
                                <td>
                                    <% if (req.requesterId) { %>
                                        <strong><%= req.requesterId.username %></strong>
                                    <% } else { %>
                                        <strong><%= req.guestName %></strong>
                                    <% } %>
                                </td>
                                <td><%= req.requestType %></td>
                                <td>
                                    <div class="action-buttons" style="display: flex; gap: 10px;">
                                        <a href="/admin/requests/<%= req._id %>" class="view-link">View Details</a>
                                        
                                        <% if (req.status === 'Pending') { %>
                                            <form action="/admin/requests/<%= req._id %>/resolve" method="POST">
                                                <button type="submit" class="resolve-btn">Mark Resolved</button>
                                            </form>
                                        <% } else if (req.status === 'Resolved') { %>
                                            <form action="/admin/requests/<%= req._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to permanently delete this request record?');">
                                                <button type="submit" class="delete-btn" style="background: #e74c3c; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">
                                                    Delete
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td>
                                No <%= currentFilter.toLowerCase() %> requests found.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div>
            <a class="nav-btn" href="/admin/index">Back to Admin Dashboard</a>
        </div>
    </div>
    <%- include('partials/footer')%>
</body>
</html>